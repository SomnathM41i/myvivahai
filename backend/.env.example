# ──────────────────────────────────────────────────────────────
# myvivahai Backend  —  copy to .env and fill your values
# ──────────────────────────────────────────────────────────────

APP_ENV=development
SECRET_KEY=change-me-to-a-very-long-random-string-32chars+
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Dev (SQLite, zero setup). Prod: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./storage/myvivahai.db

# Google OAuth → https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Copy GROQ_API_KEY directly from your old BioData-AI .env!
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
ANTHROPIC_API_KEY=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

STORAGE_BACKEND=local
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,docx,doc,jpg,jpeg,png,txt

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=myvivahai-uploads
AWS_S3_REGION=ap-south-1

REDIS_URL=redis://localhost:6379/0

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

TESSERACT_CMD=/usr/bin/tesseract
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_CHARS_PER_PAGE=5000
